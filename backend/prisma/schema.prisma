generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id                               String    @id @default(uuid())
  buyerId                          String
  sellerId                         String
  postId                           String?
  updatedAt                        DateTime  @updatedAt
  buyer                            User      @relation("Conversation_buyerIdToUser", fields: [buyerId], references: [id], onUpdate: NoAction)
  seller                           User      @relation("Conversation_sellerIdToUser", fields: [sellerId], references: [id], onUpdate: NoAction)
  messages                         Message[]
}

model Message {
  id                   String       @id @default(uuid())
  conversationId       String
  senderId             String
  text                 String
  referencedPostId     String?
  referencedMediaIndex Int?
  createdAt            DateTime     @default(now())
  conversation         Conversation @relation(fields: [conversationId], references: [id], onUpdate: NoAction)
  referencedPost       Post?        @relation(fields: [referencedPostId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sender               User         @relation(fields: [senderId], references: [id], onUpdate: NoAction)
}

model Post {
  id          String    @id @default(uuid())
  sellerId    String
  mediaUrls   String
  collageType String
  title       String
  description String?
  price       Float
  category    String
  stockStatus String
  lat         Float?
  lng         Float?
  areaLabel   String?
  createdAt   DateTime  @default(now())
  messages    Message[]
  seller      User      @relation(fields: [sellerId], references: [id])
}

model User {
  id                                       String         @id @default(uuid())
  role                                     String
  name                                     String
  avatarUrl                                String?
  bio                                      String?
  city                                     String?
  lat                                      Float?
  lng                                      Float?
  createdAt                                DateTime       @default(now())
  buyerConversations                       Conversation[] @relation("Conversation_buyerIdToUser")
  sellerConversations                      Conversation[] @relation("Conversation_sellerIdToUser")
  messages                                 Message[]
  posts                                    Post[]
}
